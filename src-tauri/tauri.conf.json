{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Luma Subtitle",
  "version": "0.1.2",
  "identifier": "com.luma.subtitle",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Luma Subtitle",
        "width": 1120,
        "height": 760,
        "minWidth": 760,
        "minHeight": 620
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico", "icons/icon.png"],
    "resources": ["resources/**/*"]
  }
}
