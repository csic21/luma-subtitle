{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Luma Subtitle",
    "version": "1.1.6",
  "identifier": "com.luma.subtitle",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Luma Subtitle",
        "width": 1120,
        "height": 760,
        "minWidth": 760,
        "minHeight": 620
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico", "icons/icon.png"],
    "resources": ["resources/**/*"],
    "createUpdaterArtifacts": true,
    "macOS": {
      "signingIdentity": "-"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEY5QjFGQUUyQjkxMUYyRkEKUldUNjhoRzU0dnF4K1VsK1V5S1IrVjRGck1Nc0UwR1BneTVONVdDd2l5QkxuNFNCUkd0dldZYW0K",
      "endpoints": [
        "https://github.com/csic21/luma-subtitle/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
